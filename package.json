{
  "name": "truco-arbiser-web",
  "version": "0.1.0",
  "description": "Port web de preservación del Truco Arbiser para DOS, con recursos recuperados y lógica reimplementada.",
  "author": "Carlos A. Leguizamón",
  "contributors": [
    "Ariel Arbiser (juego original)",
    "Enrique Arbiser (juego original)"
  ],
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "keywords": [
    "truco",
    "baraja-espanola",
    "dos",
    "preservacion",
    "vite",
    "react",
    "typescript"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "extract": "python3 scripts/extract_original_assets.py",
    "test:logic": "node --experimental-strip-types scripts/test_original_parser.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "vite": "8.1.4",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "7.0.2"
  },
  "allowScripts": {
    "fsevents": true
  }
}
